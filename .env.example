# в”Ђв”Ђ Anthology environment в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Copy to `.env` (`cp .env.example .env`) before `docker compose up`.

# `development` enables the /auth/dev-login fallback. Set to `production`
# to require real Google OAuth and disable the dev login entirely.
ENV=development

# Async SQLAlchemy connection string. `db` is the Compose service name.
DATABASE_URL=postgresql+asyncpg://anthology:anthology@db:5432/anthology

# Secret used to sign session JWTs. CHANGE THIS in any real deployment.
JWT_SECRET=change-me

# Google OAuth 2.0 / OIDC credentials. Leave the ID blank to run fully
# offline with the dev-login fallback (development only).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Internal service URLs (Compose network names).
EXTRACTION_SERVICE_URL=http://extraction:8000
SEARCH_SERVICE_URL=http://search:8000

# Allowed browser origin for CORS + post-login redirect.
WEB_ORIGIN=http://localhost:5173
